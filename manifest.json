{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "2.0.0",
  "description": "__MSG_extDescription__",
  "default_locale": "zh_CN",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "__MSG_extName__",
    "default_icon": {
      "16": "icons/icon-v4-16.png",
      "48": "icons/icon-v4-48.png",
      "128": "icons/icon-v4-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-v4-16.png",
    "48": "icons/icon-v4-48.png",
    "128": "icons/icon-v4-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://xiaohongshu.com/*",
        "https://www.xiaohongshu.com/*",
        "https://*.xiaohongshu.com/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://xiaohongshu.com/*",
        "https://www.xiaohongshu.com/*",
        "https://*.xiaohongshu.com/*"
      ],
      "js": ["lib/xhs-net-hook.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
